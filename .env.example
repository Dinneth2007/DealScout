# Required — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Optional — defaults are fine for dev
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Active provider: gemini | deepseek
LLM_PROVIDER=gemini
DEEPSEEK_API_KEY=sk-...

# Match model names to the active provider:
#   gemini  -> gemini-2.5-flash / gemini-2.5-pro
#   deepseek-> deepseek-chat (use -chat; deepseek-reasoner lacks tool calling)
# Cost-efficient mapping: researchers on flash-lite (cheapest, verified),
# intake+orchestrator on flash (flash-lite breaks intake; weak synthesis).
# Bump ORCHESTRATOR_MODEL to gemini-2.5-pro for best synthesis quality.
DEFAULT_MODEL=gemini-2.5-flash-lite
ORCHESTRATOR_MODEL=gemini-2.5-flash
RESEARCHER_MODEL=gemini-2.5-flash-lite
INTAKE_MODEL=gemini-2.5-flash

# Required for F02+ — get from https://tavily.com
TAVILY_API_KEY=tvly-...

# Observability — leave empty to disable tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
